# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ScaboPDF' do
  config = use_native_modules!

  # Local pod for the app's own native code (reading view + accessibility
  # settings TurboModule). The podspec consumes install_modules_dependencies
  # so it inherits React-Codegen and React-RCTFabric automatically.
  pod 'ScaboNative', :path => './ScaboNative'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # App-hosted XCTest unit target for the on-device extraction measurement
  # layer. :search_paths lets it `import ScaboNative` from the host app at
  # compile time without linking a second copy (no duplicate ObjC classes); the
  # symbols come from the host app at runtime. It needs no pods of its own.
  # (The XCUITest target ScaboPDFUITests is black-box and intentionally absent
  # from the Podfile.)
  target 'ScaboPDFExtractionTests' do
    inherit! :search_paths
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
